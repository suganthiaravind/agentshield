# Third-party OSS clones inside testbed/ are gitignored (1.8 GB of
# cloned reference repos like langchain, llama-index, etc.). Synthetic
# regression-target projects we author (smartsdk-lambda,
# synthetic-vuln-{java,python}-app) live in testbed/ but are tracked —
# the per-directory testbed/.gitignore handles the include/exclude logic.

# Local Claude Code agent state (per-developer, never committed)
.claude/

# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Secrets
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Trivy DB cache (large, regenerable)
.trivy-cache/
trivy-db/

# AgentShield CLI output (reports + fix-skill .md files; regenerable)
output/
